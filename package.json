{
  "name": "@jacobsandersen/glab-axi",
  "version": "0.2.0",
  "packageManager": "npm@11.16.0",
  "description": "AXI-compliant glab CLI wrapper — token-efficient TOON output, contextual suggestions, idempotent mutations",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobsandersen/glab-axi.git"
  },
  "keywords": [
    "gitlab",
    "cli",
    "agent",
    "axi",
    "toon",
    "glab"
  ],
  "bin": {
    "glab-axi": "./dist/bin/glab-axi.js"
  },
  "files": [
    "dist",
    "skills/glab-axi",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:skill": "tsx scripts/build-skill.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx bin/glab-axi.ts",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "axi-sdk-js": "^0.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0"
  }
}
